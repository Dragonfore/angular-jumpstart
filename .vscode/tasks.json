{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "docker:up",
      "type": "shell",
      "command": "docker-compose up -d",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "install:all",
      "type": "shell",
      "command": "npm run install:all",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "dev:frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Compiled successfully|Application bundle generation complete|Local:.*4200)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "development"
      }
    },
    {
      "label": "dev:backend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Nest application successfully started|listening on|Application is running on)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "development"
      }
    },
    {
      "label": "dev:full-stack",
      "dependsOn": ["dev:backend", "dev:frontend"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "build:frontend",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "build:backend",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "build:full-stack",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": ["build:frontend", "build:backend"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "prod:serve:frontend:run",
      "type": "shell",
      "command": "npx --yes serve -s dist/frontend/browser -l 4200",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Accepting connections|Serving!)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "production"
      }
    },
    {
      "label": "prod:serve:frontend",
      "dependsOn": ["build:frontend", "prod:serve:frontend:run"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "prod:backend:run",
      "type": "shell",
      "command": "npm run start:prod",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "NODE_ENV": "production"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Nest application successfully started|listening on|Application is running on)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "production"
      }
    },
    {
      "label": "prod:backend",
      "dependsOn": ["build:backend", "prod:backend:run"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "prod:run:services",
      "dependsOn": ["prod:backend:run", "prod:serve:frontend:run"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "prod:full-stack",
      "dependsOn": ["build:full-stack", "prod:run:services"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "test:backend",
      "type": "shell",
      "command": "npm test",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "test:frontend",
      "type": "shell",
      "command": "npm test",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "test",
      "problemMatcher": []
    }
  ]
}
